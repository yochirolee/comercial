{
  "name": "zas-backend",
  "version": "1.0.0",
  "description": "Sistema de gestión de ofertas y facturas",
  "main": "dist/index.js",
  "scripts": {
    "dev": "prisma generate && tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma generate && tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "local:setup": "prisma generate && prisma db push",
    "local:seed": "npm run db:seed",
    "local:reset": "npm run db:reset",
    "local:dev": "npm run dev",
    "prod:setup": "prisma generate",
    "docker:db": "docker compose --env-file docker/compose.env up -d --build db",
    "docker:up": "npm run docker:db",
    "docker:down": "docker compose --env-file docker/compose.env down",
    "docker:logs": "docker compose --env-file docker/compose.env logs -f db"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.0",
    "@types/pdfkit": "^0.13.4",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "docxtemplater": "^3.67.6",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "pdfkit": "^0.15.0",
    "pizzip": "^3.2.0",
    "prisma": "^5.10.0",
    "resend": "^6.7.0",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/pizzip": "^3.0.5",
    "tsx": "^4.7.0"
  },
  "prisma": {
    "seed": "prisma generate && tsx prisma/seed.ts"
  }
}
